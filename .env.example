# === Konfiguracja formularza kontaktowego (leady) ===
# Zmienne SERWEROWE (bez prefiksu VITE_ – NIE trafiają do bundla klienta).
# Ustaw je w panelu Vercel: Settings -> Environment Variables.
# Do lokalnego testu funkcji /api uruchom `vercel dev` z tymi zmiennymi.

# Adres wdrożenia Google Apps Script (kończy się na /exec)
LEADS_WEBHOOK_URL="https://script.google.com/macros/s/XXXXX/exec"

# Współdzielony sekret – MUSI być identyczny jak SHARED_TOKEN w skrypcie Apps Script
LEADS_TOKEN="zmien-na-wlasny-losowy-token"

# Identyfikator witryny zapisywany w arkuszu (kolumna website_id)
LEADS_WEBSITE_ID="1"
